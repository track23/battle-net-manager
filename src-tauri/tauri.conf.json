{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "BattleNetManager",
  "version": "0.1.0",
  "identifier": "com.bgm004.BattleNetManager",
  "build": {
    "frontendDist": "../webui/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd webui && npm run dev",
    "beforeBuildCommand": "cd webui && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "战网账号切换",
        "width": 900,
        "height": 750,
        "center": true,
        "decorations": true,
        "resizable": true,
        "minWidth": 700,
        "minHeight": 500,
        "backgroundColor": "#1E1E1E"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDFBQUJGMEQzRjJCNTE0NgpSV1JHVVNzL0RiK3FBUXExSUhtaiszb3JFRUVFQmh4K2RSQmZ3aWlyVm5TazhDUDJ2QWlCUU5XMwo=",
      "endpoints": [
        "https://github.com/track23/battle-net-manager/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icon"
    ],
    "resources": [],
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
